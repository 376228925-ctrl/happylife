DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: premium Doubao/Volcengine text-to-speech
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_TOKEN=
VOLCENGINE_TTS_CLUSTER=volcano_tts
VOLCENGINE_TTS_VOICE_TYPE=BV113_streaming
VOLCENGINE_TTS_VOICE_TYPE_YOUTH_GIRL=BV113_streaming
VOLCENGINE_TTS_VOICE_TYPE_SOFT_GIRL=BV001_streaming
VOLCENGINE_TTS_VOICE_TYPE_WARM_NEUTRAL=BV002_streaming

# Optional: multimodal food recognition
DEEPSEEK_VISION_MODEL=
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini

# Auth / deployment origin
AUTH_BASE_URL=https://happylife.haojie.love

# Optional: WeChat Open Platform OAuth login
WECHAT_OAUTH_APP_ID=
WECHAT_OAUTH_APP_SECRET=

# Optional: Douyin Open Platform OAuth login
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_TOKEN_URL=https://open.douyin.com/oauth/access_token/
DOUYIN_USERINFO_URL=https://open.douyin.com/oauth/userinfo/

# Optional: Tencent Cloud SMS provider for phone login codes
